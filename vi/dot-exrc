" Disable strict `vi` compatibility.
set nocp
" Do not allow ':autocmd', shell or write commands in '.exrc' files found in
" the current directory and display map commands.
set secure
" enable relative line numbers
set nu
set rnu
" Number of spaces that a '<Tab>' in the file counts for.
set ts=4
" Number of spaces to use for each step of (auto)indent.
set sw=4
" Use the appropriate number of spaces to insert a '<Tab>' in Insert mode.
set et
" Copy indent from current line when starting a new line.
set ai
" Do smart autoindenting when starting a new line.
set si
" When a bracket is inserted, briefly jump to the matching one.
set sm
" Searches should ignore case.
set ic
" Map the key sequence 'jk' to '<ESC>' in Insert mode.
ino jk <esc>
